From fb9ebf1144b2dab6cce12db79b1d1ac627cab6d7 Mon Sep 17 00:00:00 2001
From: Eric Naim <dnaim@cachyos.org>
Date: Wed, 25 Mar 2026 03:38:24 +0800
Subject: [PATCH 1/7] Kconfig: Add CONFIG_TKG

This will be used later on for the tweaks made to kernel.

Signed-off-by: Eric Naim <dnaim@cachyos.org>
---
 init/Kconfig | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/init/Kconfig b/init/Kconfig
index a7d637791..da7db5d8e 100644
--- a/init/Kconfig
+++ b/init/Kconfig
@@ -215,6 +215,10 @@ config THREAD_INFO_IN_TASK
 
 menu "General setup"
 
+config TKG
+	bool "Enable TkG kernel tweaks"
+	default y
+
 config ZENIFY
 	bool "A selection of patches from Zen/Liquorix kernel and additional tweaks for a better gaming experience"
 	default y
-- 
