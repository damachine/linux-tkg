From 075a371001ed82fb3413962d99acbc2e35497345 Mon Sep 17 00:00:00 2001
From: Galih Tama <galpt@v.recipes>
Date: Thu, 9 Jul 2026 02:13:30 +0700
Subject: [PATCH 2/6] v4.5: Infinity CPU scheduling on CFS/EEVDF

Infinity_update_weight in update_deadline() modulates EEVDF weight.
place_entity() halves vslice for futex-waking tasks.
can_migrate_task() protects interactive tasks from migration.
update_cfs_group() reduces group shares for noisy cgroups.
enqueue/dequeue track idle times for group EMA decay.

Signed-off-by: Galih Tama <galpt@v.recipes>
---
 kernel/sched/fair.c | 212 +++++++++++++++++++++++++++++++++++++++++++-
 1 file changed, 209 insertions(+), 3 deletions(-)

diff --git a/kernel/sched/fair.c b/kernel/sched/fair.c
index 3ebec186f..02e549316 100644
--- a/kernel/sched/fair.c
+++ b/kernel/sched/fair.c
@@ -55,8 +55,28 @@
 #include <uapi/linux/sched/types.h>
 
 #include "sched.h"
-#include "stats.h"
-#include "autogroup.h"
+#include "pelt.h"
+#include "infinity_sched.h"
+
+static void reweight_entity(struct cfs_rq *cfs_rq, struct sched_entity *se,
+			    unsigned long weight);
+
+/* Infinity: update EEVDF weight from EMA */
+static void infinity_update_weight(struct cfs_rq *cfs_rq,
+				   struct sched_entity *se,
+				   struct task_struct *p)
+{
+	u64 ema;
+	u32 new_weight;
+
+	ema = p->infinity.ema;
+	if (ema > INFINITY_BUDGET_MAX_NS)
+		ema = INFINITY_BUDGET_MAX_NS;
+	new_weight = infinity_calc_weight(p, ema);
+
