# Clang AutoFDO feature.
#
# Public options:
#   _autofdo=""
#   _autofdo_profile_path="~/.config/frogminer/tkg.afdo"
#
# Build flow:
#   1. Set _autofdo="true" without an existing profile for Pass 1.
#   2. Boot the profiling kernel, collect perf data, and convert it with llvm-profgen.
#   3. Set _autofdo_profile_path to the .afdo profile and rebuild for Pass 2.

[[ -v _autofdo ]] || _autofdo=""
[[ -v _autofdo_profile_path ]] || _autofdo_profile_path="~/.config/frogminer/tkg.afdo"

autofdo_enabled() {
  [[ "${_autofdo,,}" =~ ^(true|yes|y|1)$ ]]
}

autofdo_preflight() {
  local _resolved_path=""
  local _autofdo_mode=""

  if autofdo_enabled || [[ -n "$_autofdo_profile_path" ]]; then
    if [[ -n "$_autofdo_profile_path" ]]; then
      _resolved_path="${_autofdo_profile_path/#\~/$HOME}"
    fi

    if [[ -z "$_autofdo" && -n "$_resolved_path" && -f "$_resolved_path" ]]; then
      msg2 "AutoFDO: profile found at $_resolved_path - building with AutoFDO optimizations (Pass 2 mode)"
      _autofdo="true"
      _autofdo_profile_path="$_resolved_path"
    fi

    if autofdo_enabled; then
      _autofdo="true"
      msg2 "AutoFDO: enabled"
      if [[ -n "$_autofdo_profile_path" ]]; then
        _resolved_path="${_autofdo_profile_path/#\~/$HOME}"
      else
        _resolved_path=""
      fi

      if [[ -n "$_resolved_path" && -f "$_resolved_path" ]]; then
        _autofdo_mode="pass2"
        _autofdo_profile_path="$_resolved_path"
      else
        _autofdo_mode="pass1"
      fi
    fi

    if [[ "$_autofdo_mode" == "pass1" && "$_STRIP" == "true" ]]; then
      if [ "$_nofallback" = "true" ]; then
        _die "AutoFDO: Pass 1 is incompatible with _STRIP=\"true\" - set _STRIP=\"false\". Exiting."
      else
        plain "AutoFDO Pass 1 cannot be used with module stripping enabled. What would you like to do?"
        _strip_prompt_array=(
          "Disable stripping and keep AutoFDO enabled"
          "Keep stripping enabled and disable AutoFDO"
        )
        _strip_action_array=("disable-strip" "disable-autofdo")

        _default_index="0"
        _prompt_from_array "${_strip_prompt_array[@]}"

        if [ "${_strip_action_array[$_selected_index]}" = "disable-strip" ]; then
          warning "Disabling _STRIP to allow AutoFDO Pass 1"
          _STRIP="false"
        else
          warning "Disabling AutoFDO because _STRIP remains enabled"
          _autofdo=""
          _autofdo_profile_path=""
          _autofdo_mode=""
        fi
      fi
    fi

    if [[ "$_autofdo" == "true" && "$_compiler" != "llvm" ]]; then
      if [ "$_nofallback" = "true" ]; then
        _die "AutoFDO (_autofdo=\"true\") requires the LLVM compiler (_compiler=\"llvm\"). Exiting."
      else
        plain "AutoFDO requires Clang/LLVM. Would you like to use Clang/LLVM for this build?"
        _compiler_array_text=(
          "Yes: switch to Clang/LLVM and keep AutoFDO enabled"
          "No: keep current compiler selection and disable AutoFDO"
        )
        _compiler_array=("llvm" "keep")

        _default_index="0"
        _prompt_from_array "${_compiler_array_text[@]}"

        if [ "${_compiler_array[$_selected_index]}" = "llvm" ]; then
          _compiler="llvm"
        else
          warning "Disabling AutoFDO because LLVM was not selected"
          _autofdo=""
          _autofdo_profile_path=""
          _autofdo_mode=""
        fi
      fi
    fi
  fi
}

autofdo_finalize_compiler() {
  if [[ "$_autofdo" == "true" && -n "$_autofdo_profile_path" ]]; then
    _autofdo_profile_path="${_autofdo_profile_path/#\~/$HOME}"
    if [[ ! -f "$_autofdo_profile_path" ]]; then
      warning "AutoFDO profile not found: $_autofdo_profile_path - building without profile (Pass 1 mode)"
      _autofdo_profile_path=""
    fi
  fi

  echo -e "_autofdo='$_autofdo'\n_autofdo_profile_path='$_autofdo_profile_path'" >> "${_FROGMINER_TARGET:-${_where}/BIG_UGLY_FROGMINER}"
}

_config_after_lto() {
  if [[ "$_compiler_name" == "-llvm" && "$_autofdo" == "true" ]]; then
    if [[ $_kver -ge 611 ]]; then
      _enable AUTOFDO_CLANG
    else
      warning "AutoFDO (_autofdo=\"true\") requires kernel >= 6.11 - skipping CONFIG_AUTOFDO_CLANG"
    fi
  fi
}

_build_make_flags() {
  if [[ -n "$_autofdo_profile_path" && -f "$_autofdo_profile_path" ]]; then
    # Keep hook stdout clean: only emit make flags here.
    msg2 "AutoFDO: using profile ${_autofdo_profile_path}" >&2
    printf '%s\n' "CLANG_AUTOFDO_PROFILE=${_autofdo_profile_path}"
  fi
}
